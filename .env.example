# Copy to `.env.local` and fill in values from Supabase + ImageKit dashboards.
# Next.js loads `.env.local` automatically; import scripts read it too.

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose in the browser or commit real values
SUPABASE_SERVICE_ROLE_KEY=

# ImageKit (Developer -> API keys -> Private key)
IMAGEKIT_PRIVATE_KEY=

# Optional: root folder in ImageKit for CMS uploads (default: cms)
# IMAGEKIT_CMS_ROOT=cms

# Canonical domain for SEO, sitemap, Open Graph (required in production)
NEXT_PUBLIC_SITE_URL=https://www.victorgrossman.com

# --- Import scripts only (optional) ---
# SOURCE_SUPABASE_URL=
# SOURCE_SUPABASE_ANON_KEY=
# WORDPRESS_SITE=victorgrossmansberlinbulletin.wordpress.com
# PW_HEADLESS=1
